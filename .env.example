# ===========================================
# ProfitPulse Environment Variables
# Copy this to .env.local and fill in values
# ===========================================

# Shopify App Credentials
# Get these from partners.shopify.com
SHOPIFY_API_KEY=your_api_key
SHOPIFY_API_SECRET=your_api_secret

# Supabase (Database)
# Get these from supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URLs
NEXT_PUBLIC_APP_URL=https://profitpulse.vercel.app
SHOPIFY_APP_URL=https://profitpulse.vercel.app

# Billing Configuration
# Set to false for production!
SHOPIFY_BILLING_TEST=false

# Optional: PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
